{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "nucleus-business-suite-inputs",
  "title": "Nucleus Business Suite — inputs.yml Schema",
  "description": "Strict JSON Schema for validating inputs.yml — Spec-Driven Platform V10",
  "type": "object",
  "required": [
    "version",
    "app",
    "environments",
    "domains",
    "tenancy",
    "apps",
    "packages",
    "auth",
    "roles",
    "database",
    "jobs",
    "storage",
    "realtime",
    "email",
    "security",
    "data",
    "modules",
    "navigation",
    "reporting",
    "infrastructure"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 3,
      "description": "inputs.yml schema version — must be 3 for V10"
    },

    "app": {
      "type": "object",
      "required": ["name", "slug", "owner", "description", "port"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "lowercase alphanumeric + hyphens only"
        },
        "owner": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1024, "maximum": 65535 }
      }
    },

    "environments": {
      "type": "array",
      "items": { "type": "string", "enum": ["dev", "stage", "prod"] },
      "minItems": 1,
      "uniqueItems": true
    },

    "domains": {
      "type": "object",
      "required": ["dev", "stage", "prod"],
      "additionalProperties": false,
      "properties": {
        "dev": { "type": "string", "format": "uri" },
        "stage": { "type": "string", "format": "uri" },
        "prod": { "type": "string", "format": "uri" }
      }
    },

    "tenancy": {
      "type": "object",
      "required": ["mode", "strategy", "routing", "schema_prefix", "global_schema"],
      "additionalProperties": true,
      "properties": {
        "mode": {
          "type": "string",
          "const": "multi",
          "description": "Must be 'multi' — single mode not supported for this project"
        },
        "strategy": {
          "type": "string",
          "const": "schema_per_tenant",
          "description": "LOCKED — separate PostgreSQL schema per tenant"
        },
        "routing": {
          "type": "string",
          "const": "subdirectory",
          "description": "Path-based routing: /<slug>/erp"
        },
        "schema_prefix": { "type": "string", "const": "t_" },
        "global_schema": { "type": "string", "const": "public" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "framework", "description"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string", "enum": ["web", "worker", "mobile"] },
          "framework": {
            "type": "string",
            "enum": ["nextjs", "bullmq", "expo"]
          },
          "description": { "type": "string" },
          "port": { "type": "integer" },
          "workflow": { "type": "string", "enum": ["managed", "bare"] },
          "platforms": {
            "type": "array",
            "items": { "type": "string", "enum": ["ios", "android"] }
          },
          "distribution": {
            "type": "string",
            "enum": ["internal", "app_store", "play_store"]
          },
          "offline_first": { "type": "boolean" },
          "offline_storage": {
            "type": "string",
            "enum": ["watermelondb", "async_storage", "mmkv"]
          },
          "roles_with_access": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "enum": ["shared", "api-client", "db", "ui", "jobs", "storage"]
          },
          "description": { "type": "string" }
        }
      }
    },

    "auth": {
      "type": "object",
      "required": ["provider", "session_strategy", "jwt_tenant", "jwt_platform", "password_hashing"],
      "additionalProperties": true,
      "properties": {
        "provider": {
          "type": "string",
          "const": "authjs_v5"
        },
        "session_strategy": {
          "type": "string",
          "const": "jwt"
        },
        "jwt_tenant": {
          "type": "object",
          "required": ["fields"],
          "properties": {
            "fields": {
              "type": "array",
              "items": { "type": "string" },
              "contains": { "const": "userId" }
            }
          }
        },
        "jwt_platform": {
          "type": "object",
          "required": ["fields"],
          "properties": {
            "fields": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "password_hashing": { "type": "string", "const": "bcrypt" }
      }
    },

    "roles": {
      "type": "object",
      "required": ["model", "enforcement", "platform", "tenant"],
      "additionalProperties": true,
      "properties": {
        "model": {
          "type": "string",
          "const": "single_role_per_user"
        },
        "enforcement": {
          "type": "string",
          "const": "typescript_enum"
        },
        "platform": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "mobile_access": { "type": "boolean" }
            }
          }
        },
        "tenant": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "mobile_access": { "type": "boolean" },
              "is_employee": { "type": "boolean" }
            }
          }
        }
      }
    },

    "database": {
      "type": "object",
      "required": ["engine", "connection_pooling", "schema_strategy", "global_schema", "tenant_schema_prefix"],
      "additionalProperties": true,
      "properties": {
        "engine": { "type": "string", "const": "postgresql" },
        "connection_pooling": { "type": "string", "const": "pgbouncer" },
        "schema_strategy": { "type": "string", "const": "schema_per_tenant" },
        "global_schema": { "type": "string", "const": "public" },
        "tenant_schema_prefix": { "type": "string", "const": "t_" },
        "global_entities": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "tenant_entities": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },

    "cache": {
      "type": "object",
      "required": ["engine"],
      "additionalProperties": true,
      "properties": {
        "engine": { "type": "string", "const": "valkey" }
      }
    },

    "jobs": {
      "type": "object",
      "required": ["enabled", "engine", "queues"],
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "const": true },
        "engine": { "type": "string", "const": "bullmq" },
        "backend": { "type": "string", "const": "valkey" },
        "total_queues": { "type": "integer", "const": 17 },
        "queues": {
          "type": "array",
          "minItems": 17,
          "maxItems": 18,
          "items": {
            "type": "object",
            "required": ["name", "trigger", "description"],
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "trigger": { "type": "string" },
              "description": { "type": "string" },
              "retry": { "type": "integer", "minimum": 1 },
              "dlq": { "type": "boolean" },
              "rollback_on_failure": { "type": "boolean" },
              "critical": { "type": "boolean" }
            }
          }
        }
      }
    },

    "storage": {
      "type": "object",
      "required": ["enabled", "dev_provider", "prod_provider", "allowed_types", "max_file_size_mb"],
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "const": true },
        "dev_provider": { "type": "string", "const": "minio" },
        "prod_provider": { "type": "string", "const": "cloudflare_r2" },
        "allowed_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["image/jpeg", "image/png", "image/webp", "application/pdf"]
          },
          "minItems": 1
        },
        "max_file_size_mb": { "type": "integer", "const": 10 },
        "store_originals": { "type": "boolean", "const": true },
        "image_variants": { "const": "none" }
      }
    },

    "realtime": {
      "type": "object",
      "required": ["web", "mobile"],
      "additionalProperties": false,
      "properties": {
        "web": {
          "type": "object",
          "required": ["mechanism"],
          "additionalProperties": true,
          "properties": {
            "mechanism": { "type": "string", "const": "sse" }
          }
        },
        "mobile": {
          "type": "object",
          "required": ["mechanism"],
          "additionalProperties": true,
          "properties": {
            "mechanism": { "type": "string", "const": "react_query_polling" }
          }
        }
      }
    },

    "email": {
      "type": "object",
      "required": ["dev_provider", "prod_provider"],
      "additionalProperties": true,
      "properties": {
        "dev_provider": { "type": "string", "const": "mailhog" },
        "prod_provider": { "type": "string", "const": "resend" },
        "template_engine": { "type": "string" }
      }
    },

    "pdf": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "library": { "type": "string", "const": "react_pdf" }
      }
    },

    "maps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "web": { "type": "string", "const": "leaflet_openstreetmap" },
        "mobile": { "type": "string", "const": "react_native_maps_openstreetmap" }
      }
    },

    "exports": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "formats": {
          "type": "array",
          "items": { "type": "string", "enum": ["csv", "pdf", "xlsx"] }
        }
      }
    },

    "security": {
      "type": "object",
      "required": ["layers", "rate_limits", "csrf", "cors"],
      "additionalProperties": true,
      "properties": {
        "layers": {
          "type": "object",
          "required": ["L1_tenant_scoping", "L2_schema_isolation", "L3_rbac", "L4_pool_limits", "L5_audit_log", "L6_prisma_guardrails"],
          "additionalProperties": true,
          "properties": {
            "L1_tenant_scoping": { "type": "object" },
            "L2_schema_isolation": { "type": "object" },
            "L3_rbac": { "type": "object" },
            "L4_pool_limits": { "type": "object" },
            "L5_audit_log": { "type": "object" },
            "L6_prisma_guardrails": { "type": "object" }
          }
        },
        "rate_limits": { "type": "object" },
        "csrf": {
          "type": "object",
          "required": ["web", "mobile"],
          "properties": {
            "web": { "type": "string" },
            "mobile": { "type": "string" }
          }
        },
        "cors": {
          "type": "object",
          "required": ["dev", "stage", "prod"],
          "additionalProperties": false,
          "properties": {
            "dev": { "type": "string" },
            "stage": { "type": "string" },
            "prod": { "type": "string" }
          }
        }
      }
    },

    "data": {
      "type": "object",
      "required": ["retention", "gdpr", "classification"],
      "additionalProperties": true,
      "properties": {
        "retention": {
          "type": "object",
          "required": ["financial_and_credit", "dtr_attendance", "support_tickets"],
          "additionalProperties": true
        },
        "gdpr": {
          "type": "object",
          "required": ["customer_data_exportable", "customer_data_deletable"],
          "properties": {
            "customer_data_exportable": { "type": "boolean", "const": true },
            "customer_data_deletable": { "type": "boolean", "const": true }
          }
        },
        "classification": { "type": "object" }
      }
    },

    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "url_prefix", "roles"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "url_prefix": { "type": "string" },
          "roles": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "navigation": {
      "type": "object",
      "required": ["strategy"],
      "additionalProperties": true,
      "properties": {
        "strategy": {
          "type": "string",
          "const": "hardcoded_per_role_jwt_filtered"
        }
      }
    },

    "reporting": {
      "type": "object",
      "required": ["platform_dashboard", "tenant_dashboard", "module_reports"],
      "additionalProperties": false,
      "properties": {
        "platform_dashboard": { "type": "object" },
        "tenant_dashboard": { "type": "object" },
        "module_reports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["module"],
            "additionalProperties": true,
            "properties": {
              "module": { "type": "string" },
              "charts": { "type": "array" },
              "exports": { "type": "array" }
            }
          }
        }
      }
    },

    "infrastructure": {
      "type": "object",
      "required": ["compose", "production", "k8s"],
      "additionalProperties": true,
      "properties": {
        "compose": { "type": "object" },
        "production": { "type": "object" },
        "k8s": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean", "const": false }
          }
        }
      }
    },

    "ci": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "provider": { "type": "string" },
        "pipeline_steps": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
