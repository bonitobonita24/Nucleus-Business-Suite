{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "allowJs": true,
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@nucleus/shared": ["../../packages/shared/src/index.ts"],
      "@nucleus/api-client": ["../../packages/api-client/src/index.ts"]
    }
  },
  "include": ["src", "app", "*.ts", "*.tsx"],
  "exclude": ["node_modules"]
}
