# ============================================================
# Nucleus Business Suite — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=nucleus-business-suite
APP_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-32-char-secret

# ─── Database ─────────────────────────────────────────────────
# Direct connection (migrations + seeding)
DATABASE_URL=postgresql://nucleus:nucleus@localhost:5432/nucleus?schema=public

# PgBouncer connection pool (application queries)
DATABASE_POOL_URL=postgresql://nucleus:nucleus@localhost:5433/nucleus?schema=public&pgbouncer=true

POSTGRES_DB=nucleus
POSTGRES_USER=nucleus
POSTGRES_PASSWORD=nucleus

# ─── Cache / Queue ────────────────────────────────────────────
VALKEY_URL=redis://localhost:6379

# ─── Storage (MinIO dev / Cloudflare R2 prod) ─────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=nucleus-dev
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_URL=http://localhost:9000/nucleus-dev

# ─── Email (MailHog dev / Resend prod) ────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@powerbyte.app

# ─── Push Notifications (Expo) ────────────────────────────────
EXPO_ACCESS_TOKEN=

# ─── PgBouncer ────────────────────────────────────────────────
PGBOUNCER_PORT=5433
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
